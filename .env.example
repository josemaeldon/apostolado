APP_NAME="Apostolado da Oração"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Trusted Proxies (for HTTPS detection behind load balancers/reverse proxies)
# Use '*' to trust all proxies (useful for Docker, cloud environments)
# Or specify exact IPs/CIDR: '192.168.1.0/24,10.0.0.1'
TRUSTED_PROXIES=*

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=apostolado
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# Storage Configuration
# Options: local, s3, minio
# Use 'local' for local storage, 'minio' for S3-compatible MinIO storage
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# MinIO Configuration (S3-compatible object storage)
# ✅ ENABLE MinIO: Set FILESYSTEM_DISK=minio and uncomment/configure below
# 📌 Local Development: MinIO runs in docker-compose service
# 🚀 Production: Configure your MinIO endpoint and credentials
#
# Images stored in MinIO will PERSIST across deployments and git updates!
# This ensures your files are never lost during code updates.
#
# Local Development Example:
#   FILESYSTEM_DISK=minio
#   MINIO_ENDPOINT=http://minio:9000
#   MINIO_ACCESS_KEY_ID=minioadmin
#   MINIO_SECRET_ACCESS_KEY=minioadmin
#   MINIO_BUCKET=apostolado
#   MINIO_REGION=us-east-1
#   MINIO_USE_PATH_STYLE_ENDPOINT=true
#   MINIO_URL=http://localhost:9000/apostolado
#   After running docker-compose up, access MinIO at: http://localhost:9001
#
# Production Example:
#   FILESYSTEM_DISK=minio
#   MINIO_ENDPOINT=https://your-minio-server.com:9000
#   MINIO_ACCESS_KEY_ID=your-access-key
#   MINIO_SECRET_ACCESS_KEY=your-secret-key
#   MINIO_BUCKET=apostolado
#   MINIO_REGION=your-region
#   MINIO_USE_PATH_STYLE_ENDPOINT=true
#   MINIO_URL=https://your-minio-server.com/apostolado
#
FILESYSTEM_DISK=local
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET=apostolado
MINIO_REGION=us-east-1
MINIO_USE_PATH_STYLE_ENDPOINT=true
MINIO_URL=http://localhost:9000/apostolado

VITE_APP_NAME="${APP_NAME}"
